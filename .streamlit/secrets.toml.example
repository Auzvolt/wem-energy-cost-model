# .streamlit/secrets.toml.example
#
# Copy this file to .streamlit/secrets.toml and fill in real values.
# NEVER commit secrets.toml to version control — it is git-ignored.
#
# Streamlit Community Cloud: add these key-value pairs via the Secrets UI
# at https://share.streamlit.io → App settings → Secrets.

# PostgreSQL / Supabase connection string
DATABASE_URL = "postgresql://user:password@host:5432/wem_energy"

# AEMO API base URL (leave as default for public data)
AEMO_API_BASE_URL = "https://data.wa.aemo.com.au"

# AEMO APIM subscription key (leave blank for public-data-only access)
AEMO_API_KEY = ""

# Application log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL = "INFO"
