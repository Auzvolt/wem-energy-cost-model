# .streamlit/secrets.toml.example
#
# Copy this file to .streamlit/secrets.toml and fill in real values.
# NEVER commit secrets.toml to version control — it is git-ignored.
#
# Streamlit Community Cloud: add these key-value pairs via the Secrets UI
# at https://share.streamlit.io → App settings → Secrets.
#
# ⚠ IMPORTANT — ALL keys must be at the TOP LEVEL of the file (no [section] headers).
# Streamlit Cloud only exposes top-level TOML keys as environment variables.
# If DATABASE_URL is nested under a [section] heading it will NOT be visible
# to os.environ / os.getenv and the app will fail to connect.
#
# ⚠ SSL — Supabase and most managed PostgreSQL services require SSL.
# Always include ?sslmode=require in your connection string (shown below).
# The app now adds this automatically, but including it explicitly is safer.

# PostgreSQL / Supabase connection string  ← must be TOP-LEVEL (no section header)
DATABASE_URL = "postgresql://user:password@host:5432/wem_energy?sslmode=require"

# AEMO API base URL (leave as default for public data)
AEMO_API_BASE_URL = "https://data.wa.aemo.com.au"

# AEMO APIM subscription key (leave blank for public-data-only access)
AEMO_API_KEY = ""

# Application log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL = "INFO"
