# Database
DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/wem_energy

# AEMO WA API (public, no key required — override if URL changes)
AEMO_WA_BASE_URL=https://data.wa.aemo.com.au

# Pipeline scheduler
PIPELINE_REFRESH_MINUTES=30

# Optimisation solver (cbc, highs, gurobi)
SOLVER=highs

# Streamlit auth credentials (JSON dict with usernames → hashed passwords)
# Generate hashed passwords with: python -c "import streamlit_authenticator as sa; print(sa.Hasher(['mypassword']).generate())"
# Format: {"usernames": {"admin": {"name": "Admin", "password": "<bcrypt_hash>", "role": "admin"}}}
AUTH_CREDENTIALS_JSON={}

# App settings
APP_ENV=development
LOG_LEVEL=INFO
