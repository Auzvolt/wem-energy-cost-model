# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/wem_energy

# AEMO WA Open Data API
AEMO_API_BASE_URL=https://data.wa.aemo.com.au
AEMO_API_KEY=your_api_key_here

# Cookie signing key for streamlit-authenticator session tokens.
# REQUIRED before production deployment — must be a strong random secret.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
AUTH_COOKIE_KEY=replace_with_strong_random_secret

# Optional: log level
LOG_LEVEL=INFO
