# ─────────────────────────────────────────────────────────────────────────────
# WEM Energy Cost Model — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in real values for local development.
# NEVER commit .env to source control.
#
# For Streamlit Community Cloud deployment, set these values via:
#   App dashboard → ⋮ menu → Settings → Secrets (TOML format)
# ─────────────────────────────────────────────────────────────────────────────

# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string.
#
# Supabase — transaction pooler (recommended for running app):
#   DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres?pgbouncer=true
#
# Supabase — direct connection (required for Alembic migrations):
#   DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
#
# Local development:
DATABASE_URL=postgresql://user:password@localhost:5432/wem_energy

# ─── AEMO WA Open Data API ───────────────────────────────────────────────────
# Base URL for the AEMO WA Open Data portal. Leave as default unless it changes.
AEMO_API_BASE_URL=https://data.wa.aemo.com.au

# AEMO APIM subscription key. Leave blank for public-data-only access.
AEMO_API_KEY=

# ─── Authentication ──────────────────────────────────────────────────────────
# Secret key used to sign Streamlit session cookies.
# REQUIRED for production. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
AUTH_COOKIE_KEY=replace_with_strong_random_secret

# ─── Logging ─────────────────────────────────────────────────────────────────
# Python log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ─── Pipeline Monitoring & Alerting ──────────────────────────────────────────
# Cron expression for the ingestion schedule (UTC).
# Default: 0 22 * * * = 06:00 AWST daily.
PIPELINE_SCHEDULE_CRON=0 22 * * *

# Legacy: polling interval in minutes (used by run_scheduler loop mode).
PIPELINE_REFRESH_MINUTES=60

# Alert channel: log | email | slack
# log   — structured JSON written to stderr (default, zero-config)
# email — sends via SMTP (configure SMTP_* vars below)
# slack — HTTP POST to Slack Incoming Webhook (configure SLACK_WEBHOOK_URL)
ALERT_CHANNEL=log

# ─── Email Alerts (required when ALERT_CHANNEL=email) ───────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
ALERT_EMAIL_FROM=alerts@example.com
ALERT_EMAIL_TO=team@example.com

# ─── Slack Alerts (required when ALERT_CHANNEL=slack) ───────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/REPLACE/YOUR/WEBHOOK
